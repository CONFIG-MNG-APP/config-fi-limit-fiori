<mvc:View
    controllerName="zgsp26.conf.mng.filimit.confmngfefilimit.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">

  <f:DynamicPage id="mainPage" toggleHeaderOnTitleClick="false" headerPinned="true">

    <!-- ─── Title ─── -->
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <HBox alignItems="Center">
            <core:Icon src="sap-icon://money-bills" size="1.4rem" color="#0070f2" class="filTitleIcon" />
            <Title text="Expense Limit Request Maintenance" level="H2" class="filTitleText" />
          </HBox>
        </f:heading>
        <f:actions>
          <Button
            text="Submit Request"
            type="Accept"
            icon="sap-icon://paper-plane"
            press=".onSubmitRequest"
            visible="{= ${ui>/requestCreated} &amp;&amp; !${ui>/editMode} &amp;&amp; ${request>/Status} === 'DRAFT' }" />
          <Button
            text="Save Draft"
            type="Emphasized"
            icon="sap-icon://save"
            press=".onSave"
            visible="{= ${ui>/requestCreated} &amp;&amp; ${ui>/editMode} }" />
        </f:actions>
        <f:navigationActions>
          <Button icon="sap-icon://nav-back" tooltip="Back" press=".onNavBack" type="Transparent" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <!-- ─── Pinned Header: Request Context ─── -->
    <f:header>
      <f:DynamicPageHeader pinnable="false">
        <HBox alignItems="Stretch" wrap="Wrap" class="filHeaderBox">

          <!-- Request Info Card -->
          <VBox class="filInfoCard">
            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
              <core:Icon src="sap-icon://document" color="#0070f2" size="0.8rem" class="sapUiSmallMarginEnd" />
              <Text text="REQUEST" class="filSectionLabel" />
            </HBox>
            <HBox alignItems="Center" class="sapUiSmallMarginTop">
              <core:Icon src="sap-icon://key" color="#89919a" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin">
                <Text text="Request ID" class="filFieldLabel" />
                <Text text="{request>/ReqId}" class="filReqIdText" />
              </VBox>
            </HBox>
            <HBox alignItems="Center" class="sapUiTinyMarginTop">
              <core:Icon src="sap-icon://status-in-process" color="#89919a" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin">
                <Text text="Status" class="filFieldLabel" />
                <ObjectStatus text="{request>/Status}" state="{request>/StatusState}" inverted="true" />
              </VBox>
            </HBox>
          </VBox>

          <!-- Configuration Card -->
          <VBox class="filInfoCard">
            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
              <core:Icon src="sap-icon://settings" color="#0070f2" size="0.8rem" class="sapUiSmallMarginEnd" />
              <Text text="CONFIGURATION" class="filSectionLabel" />
            </HBox>
            <HBox alignItems="Center" class="sapUiSmallMarginTop">
              <core:Icon src="sap-icon://puzzle" color="#0070f2" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin">
                <Text text="Module" class="filFieldLabel" />
                <ObjectStatus text="{requestContext>/ModuleId}" state="Information" inverted="true" />
              </VBox>
            </HBox>
            <HBox alignItems="Center" class="sapUiTinyMarginTop">
              <core:Icon src="sap-icon://wrench" color="#89919a" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin">
                <Text text="Configuration Name" class="filFieldLabel" />
                <Text text="{requestContext>/ConfName}" class="filFieldValue" />
              </VBox>
            </HBox>
          </VBox>

          <!-- Request Details Card: Title + Reason -->
          <VBox class="filInfoCard filInfoCard--wide">
            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
              <core:Icon src="sap-icon://notes" color="#0070f2" size="0.8rem" class="sapUiSmallMarginEnd" />
              <Text text="REQUEST DETAILS" class="filSectionLabel" />
            </HBox>
            <HBox alignItems="Center" class="sapUiSmallMarginTop">
              <core:Icon src="sap-icon://text" color="#89919a" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin" width="100%">
                <Text text="Title" class="filFieldLabel" />
                <Input
                  value="{request>/ReqTitle}"
                  placeholder="e.g. Update expense limits for Q2"
                  editable="{= ${request>/Status} !== 'SUBMITTED' &amp;&amp; ${request>/Status} !== 'APPROVED' &amp;&amp; ${request>/Status} !== 'ACTIVE'}"
                  width="100%" />
              </VBox>
            </HBox>
            <HBox alignItems="Center" class="sapUiTinyMarginTop">
              <core:Icon src="sap-icon://edit" color="#89919a" size="0.75rem" class="filFieldIcon" />
              <VBox class="sapUiTinyMarginBegin" width="100%">
                <Text text="Reason for Change" class="filFieldLabel" />
                <TextArea
                  value="{request>/Reason}"
                  editable="{= ${request>/Status} !== 'SUBMITTED' &amp;&amp; ${request>/Status} !== 'APPROVED' &amp;&amp; ${request>/Status} !== 'ACTIVE'}"
                  rows="2"
                  width="100%"
                  placeholder="Why is this change needed?" />
              </VBox>
            </HBox>
          </VBox>

        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <!-- ─── Content ─── -->
    <f:content>
      <VBox class="sapUiMediumMarginBegin sapUiMediumMarginEnd sapUiSmallMarginTop sapUiMediumMarginBottom">

        <MessageStrip
          text="Changes made here are part of a change request and will not take effect until approved."
          type="Information"
          showIcon="true"
          class="sapUiSmallMarginBottom" />

        <!-- Table Toolbar -->
        <OverflowToolbar class="sapUiTinyMarginBottom filTableToolbar">
          <Title text="Expense Limit Lines" level="H4" />
          <ToolbarSpacer />

          <Button
            text="Create Request"
            type="Emphasized"
            icon="sap-icon://add-document"
            press=".onCreateRequest"
            visible="{= !${ui>/requestCreated} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            text="Edit"
            icon="sap-icon://edit"
            press=".onEdit"
            visible="{= ${ui>/requestCreated} &amp;&amp; !${ui>/editMode} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            text="Add Line"
            icon="sap-icon://add"
            press=".onCreate"
            visible="{= ${ui>/editMode} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            text="Import Excel"
            icon="sap-icon://upload-to-cloud"
            press=".onImportFromExcel"
            visible="{= ${ui>/editMode} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            text="Delete"
            icon="sap-icon://delete"
            type="Reject"
            press=".onDelete"
            visible="{= ${ui>/editMode} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            text="Cancel"
            icon="sap-icon://sys-cancel"
            press=".onCancel"
            visible="{= ${ui>/editMode} &amp;&amp; !${ui>/viewOnly} }" />

          <Button
            icon="sap-icon://refresh"
            tooltip="Refresh"
            type="Transparent"
            press=".onRefresh"
            visible="{= !${ui>/editMode} }" />
        </OverflowToolbar>

        <!-- Filter Panel -->
        <Panel expandable="true" expanded="false" headerText="Filter Limit Lines" class="sapUiTinyMarginBottom">
          <VBox class="sapUiSmallMargin">
            <HBox wrap="Wrap">
              <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <Label text="Search" />
                <SearchField id="searchField" width="16rem" search=".onSearch" />
              </VBox>
              <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <Label text="Environment" />
                <Input id="envInput" width="9rem" value="{filter>/EnvId}"
                  showValueHelp="true" valueHelpRequest=".onValueHelpEnv" />
              </VBox>
              <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <Label text="Expense Type" />
                <Input id="expenseTypeInput" width="10rem" value="{filter>/ExpenseType}"
                  showValueHelp="true" valueHelpRequest=".onValueHelpExpenseType" />
              </VBox>
              <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <Label text="GL Account" />
                <Input id="glAccountInput" width="10rem" value="{filter>/GlAccount}" />
              </VBox>
              <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <Label text="Currency" />
                <Select id="currencySelect" width="9rem" selectedKey="{filter>/Currency}">
                  <items>
                    <core:Item key="" text="All" />
                    <core:Item key="VND" text="VND" />
                    <core:Item key="USD" text="USD" />
                    <core:Item key="EUR" text="EUR" />
                  </items>
                </Select>
              </VBox>
            </HBox>
            <HBox justifyContent="End">
              <Button text="Go" type="Emphasized" press=".onSearch" class="sapUiSmallMarginEnd" />
              <Button text="Clear" press=".onClearFilters" />
            </HBox>
          </VBox>
        </Panel>

        <!-- ─── Limits Table ─── -->
        <Table
          id="routesTable"
          mode="MultiSelect"
          growing="true"
          growingThreshold="20"
          growingScrollToLoad="true"
          inset="false"
          noDataText="No limit lines — click 'Add Line' to add the first entry"
          class="filRoutesTable"
          items="{path: 'tableData>/rows'}">

          <columns>
            <Column width="8rem">
              <Text text="Action" />
            </Column>
            <Column width="7rem">
              <Text text="Env" />
            </Column>
            <Column width="12rem">
              <Text text="Expense Type" />
            </Column>
            <Column width="10rem" minScreenWidth="Tablet" demandPopin="true">
              <Text text="GL Account" />
            </Column>
            <Column width="10rem" minScreenWidth="Tablet" demandPopin="true" hAlign="End">
              <Text text="Approval Limit" />
            </Column>
            <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
              <Text text="Currency" />
            </Column>
            <Column width="5rem" minScreenWidth="Large" demandPopin="true" hAlign="End">
              <Text text="Ver." />
            </Column>
            <Column minScreenWidth="Large" demandPopin="true">
              <Text text="Change Note" />
            </Column>
          </columns>

          <items>
            <ColumnListItem vAlign="Middle"
              highlight="{= ${tableData>_state} === 'modified' ? 'Information' : ${tableData>_state} === 'new' ? 'Success' : ${tableData>_state} === 'deleted' ? 'Error' : 'None'}">
              <cells>

                <!-- Action badge -->
                <ObjectStatus
                  text="{= ${tableData>ActionType} === 'U' ? 'UPDATE' : ${tableData>ActionType} === 'C' ? 'CREATE' : ${tableData>ActionType} === 'X' ? 'DELETE' : '—'}"
                  state="{= ${tableData>ActionType} === 'U' ? 'Information' : ${tableData>ActionType} === 'C' ? 'Success' : ${tableData>ActionType} === 'X' ? 'Error' : 'None'}"
                  inverted="true" />

                <!-- Environment (always read-only) -->
                <ObjectStatus text="{tableData>EnvId}" state="Information" />

                <!-- Expense Type -->
                <HBox>
                  <Text text="{tableData>ExpenseType}" visible="{= !${ui>/editMode}}" class="filCellText" />
                  <Input value="{tableData>ExpenseType}" visible="{ui>/editMode}" width="100%"
                    maxLength="30"
                    valueState="{tableData>_vs_ExpenseType}"
                    valueStateText="Expense Type is required"
                    showValueHelp="true" valueHelpRequest=".onValueHelpExpenseTypeCell" />
                </HBox>

                <!-- GL Account -->
                <HBox>
                  <Text text="{tableData>GlAccount}" visible="{= !${ui>/editMode}}" class="filCellText" />
                  <Input value="{tableData>GlAccount}" visible="{ui>/editMode}" width="100%"
                    maxLength="10"
                    valueState="{tableData>_vs_GlAccount}"
                    valueStateText="GL Account is required"
                    showValueHelp="true" valueHelpRequest=".onValueHelpGlAccountCell" />
                </HBox>

                <!-- Approval Limit -->
                <HBox>
                  <Text text="{tableData>AutoApprLim}" visible="{= !${ui>/editMode}}" class="filCellText" />
                  <Input value="{tableData>AutoApprLim}" visible="{ui>/editMode}" width="100%"
                    type="Number"
                    valueState="{tableData>_vs_AutoApprLim}"
                    valueStateText="Approval Limit is required" />
                </HBox>

                <!-- Currency -->
                <HBox>
                  <Text text="{tableData>Currency}" visible="{= !${ui>/editMode}}" class="filCellText" />
                  <Select selectedKey="{tableData>Currency}" visible="{ui>/editMode}" width="100%"
                    valueState="{tableData>_vs_Currency}"
                    valueStateText="Currency must be VND, USD, or EUR">
                    <items>
                      <core:Item key="" text="" />
                      <core:Item key="VND" text="VND" />
                      <core:Item key="USD" text="USD" />
                      <core:Item key="EUR" text="EUR" />
                    </items>
                  </Select>
                </HBox>

                <!-- Version (always read-only) -->
                <Text text="{tableData>VersionNo}" class="filVersionBadge" textAlign="End" />

                <!-- Change Note -->
                <HBox>
                  <Text text="{tableData>ChangeNote}" visible="{= !${ui>/editMode}}" class="filCellText" />
                  <Input value="{tableData>ChangeNote}" visible="{ui>/editMode}" width="100%"
                    maxLength="255" />
                </HBox>

              </cells>
            </ColumnListItem>
          </items>
        </Table>

      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
